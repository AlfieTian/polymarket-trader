# ═══════════════════════════════════════════════
# Polymarket 交易系统 — 凭证配置
# ═══════════════════════════════════════════════
# 复制此文件为 .env 并填入你的凭证：
#   cp .env.template .env
#
# ⚠️ .env 已在 .gitignore 中，不会被提交

# 你的 Polygon 钱包私钥（用于签名交易）
# 建议使用专用交易钱包，不要用主钱包
POLYMARKET_PRIVATE_KEY=

# API 凭证（运行 scripts/setup_api_key.py 自动生成）
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
