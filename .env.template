# ═══════════════════════════════════════════════
# Polymarket Trading System — Credential Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your credentials:
#   cp .env.template .env
#
# .env is in .gitignore and will not be committed

# ──── Required (only these two) ────
# Polygon wallet private key (with or without 0x prefix)
# Use a dedicated trading wallet, not your main wallet
POLYMARKET_PRIVATE_KEY=

# Wallet address (0x prefix, corresponding to the private key above)
POLYMARKET_WALLET_ADDRESS=

# ──── Auto-generated (run setup_api_key.py) ────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ──── LLM Signal Source (optional, enables smart analysis) ────
# Anthropic API Key (uses Haiku for low-cost analysis)
ANTHROPIC_API_KEY=

# Or OpenAI API Key (uses gpt-4o-mini)
OPENAI_API_KEY=

# Brave Search API (news search, free tier is sufficient)
# Sign up: https://brave.com/search/api/
BRAVE_API_KEY=
