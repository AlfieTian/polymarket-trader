# ═══════════════════════════════════════════════
# Polymarket 交易系统 — 凭证配置
# ═══════════════════════════════════════════════
# 复制此文件为 .env 并填入你的凭证：
#   cp .env.template .env
#
# ⚠️ .env 已在 .gitignore 中，不会被提交

# ──── 你需要填的（仅这两项） ────
# Polygon 钱包私钥（0x 开头或不带 0x 均可）
# ⚠️ 建议使用专用交易钱包，不要用主钱包
POLYMARKET_PRIVATE_KEY=

# 钱包地址（0x 开头，与上面私钥对应）
POLYMARKET_WALLET_ADDRESS=

# ──── 以下自动生成（运行 setup_api_key.py） ────
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
